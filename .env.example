# ── Required ───────────────────────────────────────────────────────────────────
# Anthropic API key — used for document extraction (claude-haiku) and
# orchestration (claude-sonnet). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── Optional: SMS delivery via Twilio ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RECIPIENT_PHONE=

# ── Optional: Telegram Bot delivery ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional: Gmail integration ────────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=~/.config/taxbot/gmail_credentials.json
GMAIL_TOKEN_PATH=~/.config/taxbot/gmail_token.json

# ── Optional: CPA web search ──────────────────────────────────────────────────
# Falls back to DuckDuckGo Lite if neither key is set (no signup required).
TAVILY_API_KEY=
BRAVE_API_KEY=
